APP_PORT=3000

# Leave disabled outside isolated PostgreSQL testing environments.
ENABLE_POSTGRES_EXPERIMENTAL_API=false
# Requires a UUID returned by POST /api/v1/users. These public build-time values
# enable the test-only PostgreSQL UI adapter; keep both disabled in normal use.
NEXT_PUBLIC_EXPERIMENTAL_POSTGRES_UI=false
NEXT_PUBLIC_EXPERIMENTAL_POSTGRES_USER_ID=

# Social login. Set AUTH_SECRET and credentials for at least one provider to
# replace the experimental X-Climberbook-User-Id test header with a session.
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=
AUTH_ENTRA_CLIENT_ID=
AUTH_ENTRA_CLIENT_SECRET=
AUTH_ENTRA_TENANT_ID=

POSTGRES_DB=climberbook
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=climberbook_admin
POSTGRES_PASSWORD=CbLocal2026!
POSTGRES_HOST_PORT=5432
POSTGRES_AUTH_MODE=password
POSTGRES_SSLMODE=disable
POSTGRES_POOL_MAX=10

# Liquibase uses the same PostgreSQL connection by default.
# For Azure, run it with a migration/admin database user or pass an Entra access token as the password.

# Azure Database for PostgreSQL Flexible Server
# POSTGRES_AUTH_MODE=password
# POSTGRES_HOST=<server-name>.postgres.database.azure.com
# POSTGRES_PORT=5432
# POSTGRES_DB=climberbook
# POSTGRES_USER=<admin-login>
# POSTGRES_PASSWORD=<password>
# POSTGRES_SSLMODE=require
# DATABASE_URL=postgresql://<admin-login>:<url-encoded-password>@<server-name>.postgres.database.azure.com:5432/climberbook?sslmode=require

# Azure PostgreSQL with Microsoft Entra ID authentication uses POSTGRES_AUTH_MODE=entra.
# In Azure Container Apps, enable managed identity and grant it access to the PostgreSQL server.
# Locally, DefaultAzureCredential can use Azure CLI or service principal environment variables.
# POSTGRES_AUTH_MODE=entra
# POSTGRES_HOST=<server-name>.postgres.database.azure.com
# POSTGRES_PORT=5432
# POSTGRES_DB=climberbook
# POSTGRES_USER=<entra-user-or-managed-identity-name>
# POSTGRES_SSLMODE=require